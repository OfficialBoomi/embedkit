{
  "entryPoints": ["src/index.ts"],  
  "tsconfig": "tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "docs-md", // this is where the markdown docs are stored after creation
  "readme": "none",
  "hideBreadcrumbs": true,
  "hidePageTitle": false,
  "excludePrivate": false,
  "excludeExternals": true,
  "excludeInternal": true,
  "sort": ["source-order"],
  "commentStyle": "all",
  "disableSources": true,
  "hidePageHeader": true,
  "expandObjects": true,
  "expandParameters": true,
  "router": "member"
}